<UserControl
    x:Class="KindleEpubFixer.WinUI.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:KindleEpubFixer.WinUI.Models"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives">

    <Grid RowSpacing="14" Background="Transparent" SizeChanged="Root_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Height="40"
                MinWidth="132"
                Padding="18,0"
                Click="AddFiles_Click"
                Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="15" Glyph="&#xE8A5;" />
                    <TextBlock VerticalAlignment="Center" Text="添加 EPUB" />
                </StackPanel>
            </Button>

            <Button
                x:Name="StartButton"
                Grid.Column="1"
                Height="40"
                MinWidth="132"
                Padding="18,0"
                Click="StartButton_Click"
                Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="15" Glyph="&#xE768;" />
                    <TextBlock VerticalAlignment="Center" Text="开始处理" />
                </StackPanel>
            </Button>

            <CommandBar
                Grid.Column="3"
                Padding="0"
                HorizontalAlignment="Right"
                Background="Transparent"
                DefaultLabelPosition="Right"
                IsOpen="False">
                <AppBarButton Click="SelectAll_Click" Icon="SelectAll" IsCompact="True" Label="全选" />
                <AppBarButton Click="RemoveSelected_Click" Icon="Delete" IsCompact="True" Label="删除" />
                <AppBarButton Click="ClearList_Click" Icon="Clear" IsCompact="True" Label="清空" />
                <AppBarButton Click="OpenOutput_Click" Icon="OpenFile" IsCompact="True" Label="输出目录" />
            </CommandBar>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                FontSize="20"
                FontWeight="SemiBold"
                Text="{x:Bind ViewModel.SummaryText, Mode=OneWay}" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Bottom"
                Foreground="{StaticResource MutedTextBrush}"
                Text="{x:Bind ViewModel.SelectedSummaryText, Mode=OneWay}" />
        </Grid>

        <Border
            x:Name="TaskTableBorder"
            Grid.Row="2"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource SubtleBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Loaded="TaskTable_SizeChanged"
            SizeChanged="TaskTable_SizeChanged">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid
                    x:Name="HeaderGrid"
                    Padding="12,0"
                    Background="{StaticResource TableHeaderBrush}"
                    ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="56" />
                    </Grid.ColumnDefinitions>

                    <CheckBox
                        x:Name="HeaderCheckBox"
                        Width="32"
                        Height="32"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Checked="HeaderCheckBox_Changed"
                        Indeterminate="HeaderCheckBox_Changed"
                        Unchecked="HeaderCheckBox_Changed" />
                    <TextBlock Grid.Column="1" Margin="12,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="书名" />
                    <primitives:Thumb
                        Grid.Column="2"
                        Style="{StaticResource ColumnResizeThumbStyle}"
                        Tag="name-source"
                        PointerEntered="ColumnThumb_PointerEntered"
                        PointerExited="ColumnThumb_PointerExited"
                        DragStarted="ColumnThumb_DragStarted"
                        DragCompleted="ColumnThumb_DragCompleted"
                        DragDelta="ColumnThumb_DragDelta" />
                    <TextBlock Grid.Column="3" Margin="12,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="来源" />
                    <primitives:Thumb
                        Grid.Column="4"
                        Style="{StaticResource ColumnResizeThumbStyle}"
                        Tag="source-status"
                        PointerEntered="ColumnThumb_PointerEntered"
                        PointerExited="ColumnThumb_PointerExited"
                        DragStarted="ColumnThumb_DragStarted"
                        DragCompleted="ColumnThumb_DragCompleted"
                        DragDelta="ColumnThumb_DragDelta" />
                    <TextBlock Grid.Column="5" Margin="12,0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Text="状态" />
                    <TextBlock Grid.Column="7" Margin="12,0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Text="操作" />
                </Grid>

                <ListView
                    x:Name="TaskList"
                    Grid.Row="1"
                    Padding="0"
                    HorizontalContentAlignment="Stretch"
                    IsItemClickEnabled="False"
                    ItemsSource="{x:Bind Tasks}"
                    SelectionMode="None"
                    ContainerContentChanging="TaskList_ContainerContentChanging">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:EpubTask">
                            <Grid
                                MinHeight="50"
                                Padding="12,0"
                                ColumnSpacing="0"
                                Loaded="TaskRow_Loaded"
                                Unloaded="TaskRow_Unloaded">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="56" />
                                </Grid.ColumnDefinitions>

                                <CheckBox
                                    Width="32"
                                    Height="32"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Checked="TaskCheckBox_Changed"
                                    IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                    Unchecked="TaskCheckBox_Changed" />

                                <TextBlock
                                    Grid.Column="1"
                                    Margin="12,0"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Name}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="12,0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    Text="{x:Bind Folder}"
                                    TextTrimming="CharacterEllipsis" />

                                <StackPanel Grid.Column="5" Margin="12,0" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind StatusWithProgress, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis" />
                                    <ProgressBar
                                        Height="3"
                                        Maximum="100"
                                        Value="{x:Bind Progress, Mode=OneWay}" />
                                </StackPanel>

                                <Button
                                    Grid.Column="7"
                                    Width="34"
                                    MinWidth="34"
                                    Height="30"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    BorderBrush="{StaticResource SubtleBorderBrush}"
                                    Click="ShowLog_Click"
                                    CornerRadius="6"
                                    Tag="{x:Bind Id}">
                                    <FontIcon FontSize="13" Glyph="&#xE946;" />
                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="查看日志" />
                                    </ToolTipService.ToolTip>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Spacing="8">
            <ProgressBar x:Name="OverallProgress" Maximum="100" />
            <TextBlock x:Name="OutputHintText" Foreground="{StaticResource MutedTextBrush}" />
        </StackPanel>
    </Grid>
</UserControl>
