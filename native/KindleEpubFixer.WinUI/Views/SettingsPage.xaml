<UserControl
    x:Class="KindleEpubFixer.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:KindleEpubFixer.WinUI.Models">

    <Grid RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="18" CornerRadius="14" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1">
            <StackPanel Spacing="12">
                <TextBlock Text="默认保存位置" Style="{ThemeResource SubtitleTextBlockStyle}" FontSize="20" FontWeight="SemiBold" />
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="DefaultOutputBox" PlaceholderText="留空则保存到每本书所在目录下的“转换后”文件夹" />
                    <Button Grid.Column="1" Content="选择目录" Click="ChooseOutput_Click" />
                    <Button Grid.Column="2" Content="保存" Style="{ThemeResource AccentButtonStyle}" Click="SaveDefaultOutput_Click" />
                    <Button Grid.Column="3" Content="清除" Click="ClearDefaultOutput_Click" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Padding="18" CornerRadius="14" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Text="字体库与默认回落" Style="{ThemeResource SubtitleTextBlockStyle}" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="把字体加入字体库，或用“字体名 -> 回落链”覆盖默认匹配。" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <Grid Grid.Row="1" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Content="添加字体文件" Click="AddFonts_Click" />
                    <Button Grid.Column="1" Content="新增回落" Click="AddAlias_Click" />
                    <Button Grid.Column="2" Content="编辑选中" Click="EditAlias_Click" />
                    <Button Grid.Column="3" Content="删除选中" Click="DeleteAlias_Click" />
                    <Button Grid.Column="5" Content="保存设置" Style="{ThemeResource AccentButtonStyle}" Click="SaveSettings_Click" />
                </Grid>

                <ListView x:Name="AliasList" Grid.Row="2" ItemsSource="{x:Bind Aliases}" SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:FontAlias">
                            <Border Margin="0,0,0,8" Padding="14" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="210" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind Family}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Fallbacks}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</UserControl>
