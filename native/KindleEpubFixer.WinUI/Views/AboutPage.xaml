<UserControl
    x:Class="KindleEpubFixer.WinUI.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="22" CornerRadius="14" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1">
        <StackPanel Spacing="12">
            <TextBlock Text="Kindle EPUB Fixer" Style="{ThemeResource SubtitleTextBlockStyle}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="版本 1.4.0-beta.1" Foreground="{StaticResource MutedTextBrush}" />
            <TextBlock Text="Repair EPUB files for better Kindle and Send to Kindle compatibility." TextWrapping="Wrap" />
            <TextBlock Text="设计目标：尽量保留作者原始排版、字体和结构意图，只修复 Kindle / Send to Kindle 明确不兼容的问题。" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" />
            <TextBlock Text="内置字体：朱雀仿宋 v0.212，SIL Open Font License 1.1。" Foreground="{StaticResource MutedTextBrush}" />
            <TextBlock Text="当前原生前端使用 WinUI 3 / Windows App SDK；EPUB 修复核心由 Python 后端提供。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
