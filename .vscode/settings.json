{
  "dotnet.defaultSolution": "epub.sln",
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  "python.terminal.activateEnvironment": true,
  "dotnetAcquisitionExtension.allowInvalidPaths": true,
  "dotnetAcquisitionExtension.cacheTimeToLiveMultiplier": 0,
  "dotnetAcquisitionExtension.sharedExistingDotnetPath": "${workspaceFolder}\\.dotnet\\dotnet.exe",
  "dotnetAcquisitionExtension.existingDotnetPath": [
    {
      "extensionId": "ms-dotnettools.csharp",
      "path": "${workspaceFolder}\\.dotnet\\dotnet.exe"
    },
    {
      "extensionId": "ms-dotnettools.csdevkit",
      "path": "${workspaceFolder}\\.dotnet\\dotnet.exe"
    }
  ],
  "omnisharp.dotnetPath": "${workspaceFolder}\\.dotnet",
  "omnisharp.sdkPath": "${workspaceFolder}\\.dotnet\\sdk\\10.0.203",
  "terminal.integrated.env.windows": {
    "DOTNET_ROOT": "${workspaceFolder}\\.dotnet",
    "PATH": "${workspaceFolder}\\.venv\\Scripts;${workspaceFolder}\\.dotnet;${env:PATH}"
  }
}
